{

  "experimentalServices": {
      "frontend": {
          "routePrefix": "/"
      },
      "backend": {
          "root": "backend",
          "routePrefix": "/_/backend"
      }
  },

  "outputDirectory": "src",
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api" },
    { "source": "/(.*)", "destination": "/" }
  ]
}
